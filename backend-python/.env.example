# Database
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/question_mind

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI Service (set at least one)
CEREBRAS_API_KEY=your-cerebras-api-key
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Server
DEBUG=true

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# For Brevo (Bravo) on Render:
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=<your Brevo login email>
#   SMTP_PASS=<your Brevo SMTP key>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@yourcollegeDomain.edu
FROM_NAME=Question Mind

# ── Google Drive (optional — for question bank file sharing) ──────────────────
# 1. Create a Google Cloud project → enable Drive API → create Service Account
# 2. Download the service account .json key file
# 3. Share your Drive folder with the service account email (editor)
# 4. Copy the folder ID from the Drive URL and paste below
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account-key.json
