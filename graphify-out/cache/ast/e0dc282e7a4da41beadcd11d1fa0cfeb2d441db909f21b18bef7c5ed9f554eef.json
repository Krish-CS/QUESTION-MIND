 = await fetch('/python/edge_excel.py');\n        const excelCode = await excelResponse.text();\n        await py.runPythonAsync(excelCode);\n\n        console.log(\"Loading edge_cdap_parser.py...\");\n        const cdapResponse = await fetch('/python/edge_cdap_parser.py');\n        const cdapCode = await cdapResponse.text();\n        await py.runPythonAsync(cdapCode);\n\n        console.log(\"Pyodide Edge Kernel is fully initialized and active!\");\n        this.pyodide = py;\n        return py;\n      } catch (error) {\n        console.error(\"Failed to initialize Pyodide local WASM kernel:\", error);\n        throw error;\n      } finally {\n        this.isInitializing = false;\n        this.initPromise = null;\n      }\n    })", "is_member_call": false, "source_file": "D:\\QUESTION MIND\\mobile-app\\src\\lib\\pyodideBridge.ts", "source_location": "L18"}, {"caller_nid": "lib_pyodidebridge_pyodidebridge_parsesyllabustext", "callee": "set", "is_member_call": true, "source_file": "D:\\QUESTION MIND\\mobile-app\\src\\lib\\pyodideBridge.ts", "source_location": "L73"}, {"caller_nid": "lib_pyodidebridge_pyodidebridge_parsesyllabustext", "callee": "runPythonAsync", "is_member_call": true, "source_file": "D:\\QUESTION MIND\\mobile-app\\src\\lib\\pyodideBridge.ts", "source_location": "L76"}, {"caller_nid": "lib_pyodidebridge_pyodidebridge_parsesyllabustext", "callee": "parse", "is_member_call": true, "source_file": "D:\\QUESTION MIND\\mobile-app\\src\\lib\\pyodideBridge.ts", "source_location": "L82"}, {"caller_nid": "lib_pyodidebridge_pyodidebridge_parsecdaptext", "callee": "set", "is_member_call": true, "source_file": "D:\\QUESTION MIND\\mobile-app\\src\\lib\\pyodideBridge.ts", "source_location": "L91"}, {"caller_nid": "lib_pyodidebridge_pyodidebridge_parsecdaptext", "callee": "runPythonAsync", "is_member_call": true, "source_file": "D:\\QUESTION MIND\\mobile-app\\src\\lib\\pyodideBridge.ts", "source_location": "L93"}, {"caller_nid": "lib_pyodidebridge_pyodidebridge_parse