# ========================================
# PROJECT CONFIGURATION
# ========================================
# IMPORTANT: This is a STANDALONE application
# NO backend server is required - everything runs on the client
# All data is stored in IndexedDB (local app storage)

# ========== BACKEND CONFIGURATION (NOT USED) ==========
# These are kept for historical reference only
# The backend-python folder is not used in production

# Database (NOT USED - kept for reference)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=question_bank_db

# JWT (NOT USED - kept for reference)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRATION=24h

# Cerebras AI API (NOT USED - kept for reference)
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_API_URL=https://api.cerebras.ai/v1

# Frontend URL (NOT USED - kept for reference)
FRONTEND_URL=http://localhost:3000

# ========== ACTUAL CONFIGURATION ==========
# Use mobile-app/.env.local for the mobile application
# All API keys are embedded in the app via VITE_* environment variables

# Backend Port
PORT=3001
